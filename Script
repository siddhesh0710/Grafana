#!/bin/bash
set -e

echo "🚀 Installing Grafana on Ubuntu 22.04..."

# 1. Install prerequisites
sudo apt-get update -y
sudo apt-get install -y software-properties-common curl

# 2. Add Grafana GPG key
curl -fsSL https://apt.grafana.com/gpg.key | sudo gpg --dearmor -o /usr/share/keyrings/grafana-archive-keyring.gpg

# 3. Add Grafana APT repository
echo "deb [signed-by=/usr/share/keyrings/grafana-archive-keyring.gpg] https://packages.grafana.com/oss/deb stable main" | sudo tee /etc/apt/sources.list.d/grafana.list

# 4. Update package lists
sudo apt-get update -y

# 5. Install Grafana
sudo apt-get install -y grafana

# 6. Start and enable Grafana service
sudo systemctl enable grafana-server
sudo systemctl start grafana-server
sudo systemctl status grafana-server

echo "✅ Grafana installation complete!"
echo "Access Grafana at: http://<server-ip>:3000 (default admin:admin)"
